---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import DownloadButton from '../components/DownloadButton.astro';
import RelatedWorkflows from '../components/RelatedWorkflows.astro';
import CategoryPills from '../components/CategoryPills.astro';
import { render } from 'astro:content';
import type { WorkflowEntry } from '../lib/workflows';
import { downloadUrl } from '../lib/workflows';
import { absoluteUrl } from '../lib/site';
import {
  breadcrumbSchema,
  workflowSoftwareSchema,
  howToSchema,
  jsonLdScript,
} from '../lib/schema';

interface Props {
  entry: WorkflowEntry;
  related: WorkflowEntry[];
}

const { entry, related } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const url = absoluteUrl(`/workflows/${data.slug}`);

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Workflows', path: '/workflows' },
  { name: data.title, path: `/workflows/${data.slug}` },
];

const extraSchema = [
  breadcrumbSchema(breadcrumbs),
  workflowSoftwareSchema({
    name: data.title,
    description: data.description,
    url,
    fileFormat: data.format,
    datePublished: data.dateAdded.toISOString().split('T')[0],
  }),
  howToSchema({
    name: `How to import ${data.title}`,
    description: `Import and run ${data.title} in n8n`,
    steps: [
      { name: 'Download', text: `Download the ${data.format.toUpperCase()} file from n8n.gjam.in` },
      { name: 'Import', text: 'Open n8n → Workflows → Import from File' },
      { name: 'Credentials', text: 'Connect required integrations listed on this page' },
      { name: 'Activate', text: 'Test manually, then enable triggers when ready' },
    ],
  }),
];
---

<BaseLayout
  title={data.title}
  description={data.description}
  canonical={url}
  ogType="article"
  jsonLd={extraSchema}
>
  <article class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:py-14">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mt-6 border-b border-slate-800 pb-8">
      <CategoryPills categories={[data.category]} />
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-white sm:text-4xl">
        {data.title}
      </h1>
      <p class="mt-4 text-lg text-slate-300">{data.description}</p>
      <div class="mt-6 flex flex-wrap items-center gap-4 text-sm text-slate-400">
        <span>{data.fileSize}</span>
        <span>·</span>
        <span class="uppercase">{data.format}</span>
        {data.nodesCount && (
          <>
            <span>·</span>
            <span>{data.nodesCount} nodes</span>
          </>
        )}
      </div>
      <div class="mt-8">
        <DownloadButton file={data.file} format={data.format} title={data.title} />
      </div>
    </header>

    <section class="mt-8 grid gap-6 sm:grid-cols-2">
      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-400">Use cases</h2>
        <ul class="mt-3 space-y-2 text-slate-300">
          {data.useCases.map((u) => (
            <li class="flex gap-2">
              <span class="text-brand-400">→</span>
              {u}
            </li>
          ))}
        </ul>
      </div>
      <div class="rounded-xl border border-slate-800 bg-slate-900/50 p-5">
        <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-400">
          Required integrations
        </h2>
        <ul class="mt-3 flex flex-wrap gap-2">
          {data.requiredIntegrations.map((i) => (
            <li class="rounded-full bg-slate-800 px-3 py-1 text-sm text-slate-200">{i}</li>
          ))}
        </ul>
        <div class="mt-4 flex flex-wrap gap-2">
          {data.tags.map((t) => (
            <span class="text-xs text-brand-300">#{t}</span>
          ))}
        </div>
      </div>
    </section>

    <div class="prose-content mt-10">
      <Content />
    </div>

    <div class="mt-10 rounded-xl border border-brand-800/50 bg-brand-950/30 p-6">
      <p class="font-medium text-white">Direct download</p>
      <p class="mt-1 text-sm text-slate-400">
        <a href={downloadUrl(data.file)} class="text-brand-400 hover:underline">
          {data.file}
        </a>
      </p>
      <div class="mt-4">
        <DownloadButton file={data.file} format={data.format} title={data.title} />
      </div>
    </div>

    {related.length > 0 && (
      <RelatedWorkflows workflows={related} class="mt-14" />
    )}
  </article>
</BaseLayout>
