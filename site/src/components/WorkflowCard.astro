---
import type { WorkflowEntry } from '../lib/workflows';
import { getCategoryLabel, downloadUrl } from '../lib/workflows';
import { CATEGORIES, type CategorySlug } from '../lib/site';

interface Props {
  workflow: WorkflowEntry;
}

const { workflow } = Astro.props;
const { data } = workflow;
const cat = CATEGORIES[data.category as CategorySlug];
---

<article
  class="group flex flex-col rounded-xl border border-slate-800 bg-slate-900/40 p-5 transition hover:border-brand-700/50 hover:bg-slate-900/80"
>
  <div class="flex items-start justify-between gap-2">
    <span class="rounded-full bg-slate-800 px-2.5 py-0.5 text-xs font-medium text-brand-300">
      {cat?.label ?? data.category}
    </span>
    <span class="text-xs uppercase text-slate-500">{data.format}</span>
  </div>
  <h2 class="mt-3 text-lg font-semibold text-white group-hover:text-brand-300">
    <a href={`/workflows/${data.slug}`} class="after:absolute after:inset-0 relative">
      {data.title}
    </a>
  </h2>
  <p class="mt-2 flex-1 text-sm text-slate-400 line-clamp-2">{data.description}</p>
  <div class="mt-4 flex items-center justify-between text-xs text-slate-500">
    <span>{data.fileSize}</span>
    <a
      href={downloadUrl(data.file)}
      class="relative z-10 font-medium text-brand-400 hover:text-brand-300"
      download
    >
      Download
    </a>
  </div>
</article>
