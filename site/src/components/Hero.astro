---
interface Props {
  title: string;
  subtitle: string;
  ctaHref?: string;
  ctaLabel?: string;
  secondaryHref?: string;
  secondaryLabel?: string;
}

const {
  title,
  subtitle,
  ctaHref = '/workflows',
  ctaLabel = 'Browse free workflows',
  secondaryHref,
  secondaryLabel,
} = Astro.props;
---

<section class="relative overflow-hidden border-b border-slate-800 bg-gradient-to-b from-slate-900 to-slate-950">
  <div
    class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-brand-900/30 via-transparent to-transparent"
  >
  </div>
  <div class="relative mx-auto max-w-6xl px-4 py-16 sm:px-6 sm:py-24 lg:py-28">
    <p class="text-sm font-medium uppercase tracking-wider text-brand-400">
      Free n8n workflows · AI agents · Templates
    </p>
    <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight text-white sm:text-5xl lg:text-6xl">
      {title}
    </h1>
    <p class="mt-6 max-w-2xl text-lg text-slate-300 sm:text-xl">{subtitle}</p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href={ctaHref}
        class="inline-flex items-center rounded-lg bg-brand-600 px-6 py-3 font-medium text-white transition hover:bg-brand-500"
      >
        {ctaLabel}
      </a>
      {
        secondaryHref && secondaryLabel && (
          <a
            href={secondaryHref}
            class="inline-flex items-center rounded-lg border border-slate-600 px-6 py-3 font-medium text-slate-200 transition hover:border-slate-500 hover:bg-slate-800"
          >
            {secondaryLabel}
          </a>
        )
      }
    </div>
  </div>
</section>
