---
import { downloadUrl } from '../lib/workflows';

interface Props {
  file: string;
  format: string;
  title: string;
}

const { file, format, title } = Astro.props;
const href = downloadUrl(file);
---

<a
  href={href}
  download
  class="inline-flex items-center gap-2 rounded-lg bg-brand-600 px-6 py-3 font-semibold text-white shadow-lg shadow-brand-900/30 transition hover:bg-brand-500"
>
  <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
  </svg>
  Download {format.toUpperCase()} — {title}
</a>
