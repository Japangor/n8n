---
import { SITE } from '../lib/site';

const guides = [
  { href: '/what-is-n8n', label: 'What is n8n' },
  { href: '/n8n-automation', label: 'Automation' },
  { href: '/n8n-self-host', label: 'Self-host' },
  { href: '/n8n-pricing', label: 'Pricing' },
  { href: '/n8n-mcp', label: 'MCP' },
  { href: '/n8n-api', label: 'API' },
];

const compare = [
  { href: '/n8n-vs-zapier', label: 'vs Zapier' },
  { href: '/n8n-vs-make', label: 'vs Make' },
  { href: '/openclaw-vs-n8n', label: 'vs OpenClaw' },
  { href: '/flowise-vs-n8n', label: 'vs Flowise' },
];

const site = [
  { href: '/workflows', label: 'All workflows' },
  { href: '/n8n-templates', label: 'Templates' },
  { href: '/n8n-github', label: 'n8n GitHub' },
  { href: '/rss.xml', label: 'RSS feed' },
];

const company = [
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/privacy', label: 'Privacy' },
  { href: '/terms', label: 'Terms' },
  { href: '/disclaimer', label: 'Disclaimer' },
];
---

<footer class="border-t border-slate-800 bg-slate-950">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-5">
      <div class="lg:col-span-2">
        <p class="font-semibold text-white">{SITE.name}</p>
        <p class="mt-2 text-sm text-slate-400">{SITE.description}</p>
        <p class="mt-4 text-sm text-slate-400">
          Editor: <a href={`mailto:${SITE.email}`} class="hover:text-white">{SITE.email}</a>
        </p>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-300">Guides</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            guides.map((l) => (
              <li>
                <a href={l.href} class="text-slate-400 hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-300">Compare</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            compare.map((l) => (
              <li>
                <a href={l.href} class="text-slate-400 hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
        <p class="mt-6 text-sm font-semibold text-slate-300">Site</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            site.map((l) => (
              <li>
                <a href={l.href} class="text-slate-400 hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
      <div>
        <p class="text-sm font-semibold text-slate-300">Company</p>
        <ul class="mt-3 space-y-2 text-sm">
          {
            company.map((l) => (
              <li>
                <a href={l.href} class="text-slate-400 hover:text-white">
                  {l.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </div>
    <div class="mt-10 border-t border-slate-800 pt-6 text-center text-xs text-slate-500">
      <p>
        © {new Date().getFullYear()} {SITE.author}. Free n8n templates for education and productivity.
        n8n is a trademark of n8n GmbH; this site is not affiliated.
      </p>
      <p class="mt-2">
        <a href="/privacy" class="hover:text-slate-300">Privacy</a>
        <span class="mx-2">·</span>
        <a href="/terms" class="hover:text-slate-300">Terms</a>
        <span class="mx-2">·</span>
        <a href="/disclaimer" class="hover:text-slate-300">Disclaimer</a>
        <span class="mx-2">·</span>
        <a href="/contact" class="hover:text-slate-300">Contact</a>
      </p>
    </div>
  </div>
</footer>
