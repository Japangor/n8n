---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  items: FAQItem[];
  class?: string;
}

const { items, class: className = '' } = Astro.props;
---

<section class={className}>
  <h2 class="text-2xl font-bold text-white">Frequently asked questions</h2>
  <dl class="mt-6 space-y-6">
    {
      items.map((item) => (
        <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-5">
          <dt class="font-semibold text-white">{item.question}</dt>
          <dd class="mt-2 text-slate-300">{item.answer}</dd>
        </div>
      ))
    }
  </dl>
</section>
