---
import { SITE } from '../lib/site';

const nav = [
  { href: '/workflows', label: 'Workflows' },
  { href: '/free-n8n-workflows', label: 'Free' },
  { href: '/n8n-ai-agents', label: 'AI Agents' },
  { href: '/n8n-docs', label: 'Docs' },
  { href: '/n8n-docker', label: 'Docker' },
];
---

<header class="sticky top-0 z-50 border-b border-slate-800/80 bg-slate-950/90 backdrop-blur-md">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6">
    <a href="/" class="flex items-center gap-2 font-semibold text-white">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-sm font-bold"
        >n8</span
      >
      <span class="hidden sm:inline">{SITE.name}</span>
    </a>
    <nav class="hidden items-center gap-6 md:flex" aria-label="Main">
      {
        nav.map((item) => (
          <a
            href={item.href}
            class="text-sm text-slate-300 transition hover:text-white"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <a
      href="/workflows"
      class="hidden rounded-lg bg-brand-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-brand-500 sm:inline-block"
    >
      Browse templates
    </a>
    <button
      type="button"
      class="md:hidden rounded-lg border border-slate-700 p-2 text-slate-300"
      aria-label="Open menu"
      id="menu-toggle"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
    </button>
  </div>
  <nav
    id="mobile-menu"
    class="hidden border-t border-slate-800 px-4 py-4 md:hidden"
    aria-label="Mobile"
  >
    <div class="flex flex-col gap-3">
      {
        nav.map((item) => (
          <a href={item.href} class="text-slate-300 hover:text-white">
            {item.label}
          </a>
        ))
      }
      <a href="/workflows" class="text-brand-400 font-medium">All workflows →</a>
    </div>
  </nav>
</header>
<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
