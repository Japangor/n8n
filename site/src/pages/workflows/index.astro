---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WorkflowGrid from '../../components/WorkflowGrid.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getAllWorkflows } from '../../lib/workflows';
import { itemListSchema, breadcrumbSchema } from '../../lib/schema';
import { absoluteUrl } from '../../lib/site';

const workflows = await getAllWorkflows();
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Workflows', path: '/workflows' },
];

const listItems = workflows.map((w) => ({
  name: w.data.title,
  url: absoluteUrl(`/workflows/${w.data.slug}`),
}));
---

<BaseLayout
  title="Free n8n Workflows & Templates"
  description="Browse and download free n8n workflows, JSON templates, and ZIP packs. AI agents, lead gen, email, video, voice, and social automation."
  jsonLd={[
    breadcrumbSchema(breadcrumbs),
    itemListSchema('Free n8n workflows', listItems),
  ]}
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <Breadcrumbs items={breadcrumbs} />
    <header class="mt-6 max-w-2xl">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">n8n workflows & templates</h1>
      <p class="mt-4 text-lg text-slate-300">
        {workflows.length} free workflows for import into n8n Cloud or self-hosted instances.
        Matches searches for <strong>n8n workflows</strong>, <strong>n8n templates</strong>, and
        <strong>n8n workflow github</strong> style resources.
      </p>
    </header>
    <WorkflowGrid workflows={workflows} class="mt-10" />
  </div>
</BaseLayout>
