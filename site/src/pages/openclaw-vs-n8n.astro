<GuideLayout
  title="OpenClaw vs n8n — Honest Comparison (2025)"
  description="OpenClaw vs n8n (+450% rising in India): when to use each, feature differences, and how to combine them. Includes decision criteria for AI agent stacks."
  path="/openclaw-vs-n8n"
  breadcrumbs={[
    { name: 'Home', path: '/' },
    { name: 'OpenClaw vs n8n', path: '/openclaw-vs-n8n' },
